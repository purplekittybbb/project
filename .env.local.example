# Copy to .env.local and fill in to enable real Claude responses in the Analyst Copilot.
# Without this key, /api/chat and /api/explain fall back to deterministic,
# fully-grounded rule-based answers — the demo never breaks and never hallucinates.
ANTHROPIC_API_KEY=

# Supabase Auth (email/password). Get these from your Supabase project:
#   Project Settings → API → Project URL and anon/public key.
# They must use the NEXT_PUBLIC_ prefix so the browser auth client can read them.
# The anon key is safe to expose publicly; passwords are hashed & stored by Supabase.
# Without these, login/signup fall back to demo mode (straight to /dashboard).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
